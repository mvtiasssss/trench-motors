# =====================================================================
# Trench Motors — variables de entorno
# Copia este archivo a `.env.local` y completa los valores reales.
# `.env.local` está ignorado por git (ver .gitignore) y NUNCA se commitea.
# =====================================================================

# URL del proyecto de Supabase (Project Settings → API → Project URL).
# Es pública: se expone al navegador (prefijo NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=

# Clave anónima (anon/public) de Supabase (Project Settings → API → anon public).
# Es pública y respeta las políticas de Row Level Security (RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service_role de Supabase (Project Settings → API → service_role).
# SECRETA: omite RLS y tiene acceso total. Úsala SOLO en el servidor.
# Nunca la expongas al navegador ni la prefijes con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# API key de Resend para el envío de correos transaccionales.
# SECRETA: úsala solo en el servidor (Route Handlers / Server Actions).
RESEND_API_KEY=

# Remitente de los correos (debe ser de un dominio verificado en Resend).
# Para pruebas puedes usar onboarding@resend.dev.
RESEND_FROM_EMAIL=

# Destinatario de las notificaciones de leads (a quién le llegan los formularios).
RESEND_TO_EMAIL=

# ID de medición de Google Analytics 4 (formato G-XXXXXXXXXX).
# Es pública. Si no se define, el script de Analytics no se carga (no rompe nada).
NEXT_PUBLIC_GA_ID=
